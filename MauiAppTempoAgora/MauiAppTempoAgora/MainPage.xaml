<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppTempoAgora.MainPage">

    <Grid RowDefinitions="Auto, Auto, Auto, 100, *">
        <Button Grid.Row="0" Text="Obter Minha Localização" Clicked="Button_Clicked_Localizacao" />

        <Grid Grid.Row="1" ColumnDefinitions="*, Auto" ColumnSpacing="10" Margin="10">
            <Entry Grid.Column="0" x:Name="txt_cidade" Placeholder="Qual cidade?" />
            <Button Grid.Column="1" Text="Pesquisar" Clicked="Button_Clicked_Previsao" />
        </Grid>

        <Label Grid.Row="2" x:Name="lbl_previsao" />
        <Image Grid.Row="3" x:Name="img_icone" />     
        <WebView Grid.Row="4" x:Name="wv_mapa" Source="abobrinha" />
    </Grid>
</ContentPage>
